# Copy this file to `.env` and replace values with real secrets.
# Never commit `.env`.

DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret-key

DB_NAME=dbname
DB_USER=dbuser
DB_PASSWORD=dbpass
DB_HOST=localhost
DB_PORT=5432

TELEGRAM_TOKEN=your-telegram-token
TELEGRAM_PAYMENTS_PROVIDER_TOKEN=your-telegram-payments-provider-token
TELEGRAM_BOT_USERNAME=your_bot_username
WEBAPP_URL=https://vocabume.k1prod.com
OPENAI_API_KEY=your-openai-key
ALERT_CHAT_ID=your-telegram-id
CSRF_TRUSTED_ORIGINS=https://vocabume.k1prod.com
# Redis-backed OpenAI concurrency guard. Keep these intentionally conservative
# until the account-level OpenAI limits are measured in production.
OPENAI_REDIS_URL=redis://127.0.0.1:6379/3
OPENAI_MAX_CONCURRENCY=8
OPENAI_MAX_INFLIGHT_PER_USER=1
OPENAI_SLOT_WAIT_SECONDS=10
OPENAI_SLOT_TTL_SECONDS=300
# Circuit breaker: after this many consecutive provider failures, temporarily
# reject new paid requests. Keep it enabled in production to prevent retry storms.
OPENAI_CIRCUIT_FAILURE_THRESHOLD=5
OPENAI_CIRCUIT_RESET_SECONDS=60
# Cross-process daily OpenAI spend cap in USD (UTC day). Set to 0 only to
# disable the cap deliberately. Reservations stop concurrent workers exceeding it.
OPENAI_DAILY_BUDGET_USD=5.00
# Conservative holds are reconciled to actual token usage when OpenAI returns it.
OPENAI_TEXT_REQUEST_RESERVE_USD=0.02
OPENAI_TRANSCRIPTION_REQUEST_RESERVE_USD=0.25

# Shared Redis is required for production-wide rate limits and Celery workers.
# Local development can keep the Django defaults when background workers are off.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/2

# Production hardening (when DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
